---
import BaseLayout from '../layouts/BaseLayout.astro';
import MtebDashboard from '../components/mteb_dashboard.svelte';
import DataDebugPanel from '../components/DataDebugPanel.svelte';
import leaderboard from '../lib/data/mteb_de_leaderboard.json';
import manifest from '../lib/data/manifest.json';
import type { LeaderboardSnapshot, Manifest } from '../lib/types/mteb';
import { formatScore, formatParams, logoForModel } from '../lib/types/mteb';
import { dimSourceLabel, priceSourceLabel } from '../lib/mteb_filter';

const data = leaderboard as LeaderboardSnapshot;
const meta = manifest as Manifest;
const base = import.meta.env.BASE_URL;
const models = data.models.sort((a, b) => b.avg_score - a.avg_score);
const generatedAt = new Date(meta.generated_at).toLocaleString('en-GB', { timeZone: 'UTC' }) + ' UTC';
const pickerRules = data.picker_rules ?? [];
const wfDeploy =
  'https://github.com/IxI-Enki/project-diploma-performance-analysis/actions/workflows/deploy_pages.yml';
const wfData =
  'https://github.com/IxI-Enki/project-diploma-performance-analysis/actions/workflows/update_data.yml';
const hfDims = models.filter((m) => m.dim_source === 'hf_hub' || m.dim_source === 'mteb_api').length;
const litellmPrices = models.filter((m) => m.price_source === 'litellm').length;
const openrouterPrices = models.filter((m) => m.price_source === 'openrouter').length;
const liveOk = data.source === 'mteb/deu-v1-api';
const debugSources = [
  {
    id: 'mteb_api',
    label: 'MTEB(deu, v1) leaderboard API',
    status: liveOk ? 'ok' : data.fallback ? 'fail' : 'warn',
    detail: data.source,
    workflowUrl: wfDeploy,
  },
  {
    id: 'hf_hub',
    label: 'HF Hub embedding dimensions',
    status: hfDims > 0 ? 'ok' : 'warn',
    detail: `${hfDims}/${models.length} models`,
    workflowUrl: wfDeploy,
  },
  {
    id: 'litellm',
    label: 'LiteLLM pricing enrichment',
    status: litellmPrices > 0 ? 'ok' : 'warn',
    detail: litellmPrices > 0 ? `${litellmPrices} priced` : 'No HF slugs matched LiteLLM embedding keys',
    workflowUrl: wfDeploy,
  },
  {
    id: 'openrouter',
    label: 'OpenRouter pricing enrichment',
    status: openrouterPrices > 0 ? 'ok' : 'warn',
    detail: openrouterPrices > 0 ? `${openrouterPrices} priced` : 'N/A — OpenRouter has no embedding API prices',
    workflowUrl: wfDeploy,
  },
  {
    id: 'seed',
    label: 'Seed/bootstrap snapshot (--seed-only)',
    status: data.fallback === true ? 'fail' : 'unknown',
    workflowUrl: wfData,
  },
  {
    id: 'validate',
    label: 'validate_json schema gate',
    status: models.length >= 20 ? 'ok' : 'fail',
    detail: `${models.length} models`,
    workflowUrl: wfDeploy,
  },
  {
    id: 'deploy',
    label: 'Full deploy pipeline (fetch + build + Pages)',
    status: 'unknown',
    workflowUrl: wfDeploy,
  },
];
---

<BaseLayout
  fallback={data.fallback === true}
  generatedAt={generatedAt}
  generatedAtIso={meta.generated_at}
  source={data.source}
>
  <section>
    <div class="wrap">
      <DataDebugPanel
        client:load
        generatedAt={meta.generated_at}
        staleWarning={meta.stale_warning}
        fallback={data.fallback === true}
        sources={debugSources}
      />
      <div class="card section-band">
        <div class="sec-head">
          <h2>Leaderboard</h2>
        </div>
        <div class="table-scroll leaderboard-scroll">
          <table class="data leaderboard-table" id="leaderboard-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Model</th>
                <th>Avg</th>
                <th>Retrieval</th>
                <th>Clustering</th>
                <th>Classification</th>
                <th>Params</th>
                <th>Dim</th>
                <th>Price/M</th>
              </tr>
            </thead>
            <tbody>
              {models.map((m, i) => {
                const logo = logoForModel(m.model_id);
                return (
                  <tr>
                    <td>{i + 1}</td>
                    <td class="model-cell">
                      {logo && <img class="model-logo" src={`${base}img/logos/${logo}`} alt="" width="28" height="28" loading="lazy" />}
                      <span class="mono">{m.model_id}</span>
                    </td>
                    <td><strong>{formatScore(m.avg_score, 2)}</strong></td>
                    <td>{formatScore(m.tasks.retrieval)}</td>
                    <td>{formatScore(m.tasks.clustering)}</td>
                    <td>{formatScore(m.tasks.classification)}</td>
                    <td>{formatParams(m.params_m)}</td>
                    <td>
                      {m.embedding_dim != null ? (
                        <span>
                          {m.embedding_dim}
                          {dimSourceLabel(m.dim_source) && (
                            <span class="src-tag" title="Aggregator source">{dimSourceLabel(m.dim_source)}</span>
                          )}
                        </span>
                      ) : '—'}
                    </td>
                    <td>
                      {m.price_input_per_mtok != null ? (
                        <span>
                          ${m.price_input_per_mtok.toFixed(4)}
                          {priceSourceLabel(m.price_source) && (
                            <span class="src-tag" title="Aggregator source">{priceSourceLabel(m.price_source)}</span>
                          )}
                        </span>
                      ) : '—'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="wrap">
      <MtebDashboard client:visible models={models} baseUrl={base} />
    </div>
  </section>

  {pickerRules.length > 0 && (
    <section class="section-tight">
      <div class="wrap">
        <div class="card">
          <h2>Model picker rules</h2>
          <ul class="picker-rules">
            {pickerRules.map((rule) => (
              <li>
                <strong>{rule.task}</strong> ({rule.resources}) → <span class="mono">{rule.model_id}</span>
                <p>{rule.reason_en}</p>
                <p class="de-reason">{rule.reason_de}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <section class="section-tight">
    <div class="wrap">
      <div class="card">
        <h2>Methodology</h2>
        <p style="margin-top:10px;color:var(--muted);font-size:.92rem">
          MTEB aggregates task-specific scores. Retrieval uses nDCG-style ranking metrics;
          clustering measures group quality on German datasets. Scores are normalized for comparison
          on the public leaderboard. Dimension and pricing data may come from HF Hub or secondary
          aggregators (LiteLLM, OpenRouter) and are labeled accordingly.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .leaderboard-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .src-tag {
    font-size: 0.65rem;
    margin-left: 4px;
    padding: 1px 4px;
    border-radius: 3px;
    background: rgba(234, 179, 8, 0.25);
  }
  .picker-rules { list-style: none; padding: 0; }
  .picker-rules li { margin-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 12px; }
  .picker-rules p { margin: 4px 0 0; font-size: 0.9rem; color: var(--muted); }
  .de-reason { font-style: italic; }
  @media (max-width: 768px) {
    .leaderboard-table th:nth-child(5),
    .leaderboard-table td:nth-child(5),
    .leaderboard-table th:nth-child(6),
    .leaderboard-table td:nth-child(6),
    .leaderboard-table th:nth-child(7),
    .leaderboard-table td:nth-child(7) { display: none; }
    .leaderboard-table .model-cell .mono { font-size: 0.72rem; }
    .leaderboard-table td strong { font-size: 0.9rem; }
  }
</style>
